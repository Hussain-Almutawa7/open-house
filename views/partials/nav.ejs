<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authentication App</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <a href="/">Home</a>
        <% if(user) { %>
          <form action="/auth/sign-out?_method=DELETE" method="POST">
            <button class="sign-out" type="submit">Sign Out</button>
          </form>
          <a class="nav-link active" aria-current="page" href="/dashboard"> View Dashboard</a>
          <% } else { %>
            <a class="nav-link active" aria-current="page" href="/auth/sign-up">Sign Up</a>
            <a class="nav-link active" aria-current="page" href="/auth/sign-in">Sign In</a>
          <% } %>
    </nav>
