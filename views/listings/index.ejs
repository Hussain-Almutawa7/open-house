<%- include("../partials/nav") %>

<h1>All Listing</h1>

<% allList.forEach(list => { %>
    <h2><%= list.price %></h2>
    <h2><%= list.streetAddress %></h2>
    <h2><%= list.city %></h2>
    <h2><%= list.size %></h2>
    <a href="/listings/<%= list.id %>">
        <img src="<%= list.image %>" alt="image" width="200"> <br>
        <span>A listing in <%= list.city %> owned by: <%= list.owner.username %></span>
    </a>
    <hr>
<% }) %>

</body>

</html>